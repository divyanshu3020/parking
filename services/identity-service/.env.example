# Server configuration
PORT=4000
NODE_ENV=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Email sender address
EMAIL_FROM=noreply@parking.com

# Production SMTP settings (used only when NODE_ENV=production)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_SECURE=false

# Development / Ethereal test account (optional)
# If you want local email testing, set these or use a real SMTP account.
ETHEREAL_USER=your-ethereal-user
ETHEREAL_PASS=your-ethereal-password
